@using MvcProject.ViewModels
@model ApplicationUserLoginVM
@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

<main class="d-flex flex-column flex-md-row w-100 vh-100">
    <!-- Left Panel -->
    <section class="left-bg-gradient position-relative flex-grow-1 d-none d-md-flex flex-column justify-content-between p-5 text-white overflow-hidden">
        <!-- Decorative background shapes -->
        <div class="glass-shape-1"></div>
        <div class="glass-shape-2"></div>
        
        <!-- Top Branding -->
        <div class="position-relative z-1 d-flex align-items-center gap-2">
            <div class="d-flex align-items-center justify-content-center rounded" style="width: 32px; height: 32px; background-color: rgba(255,255,255,0.2);">
                <svg class="text-white" style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect height="18" rx="4" stroke-width="2" width="18" x="3" y="3"></rect><path d="M8 10v4m4-6v6m4-2v2" stroke-linecap="round" stroke-width="2"></path></svg>
            </div>
            <span class="fs-5 fw-semibold tracking-wide">Velocity</span>
        </div>
        
        <!-- Center Content -->
        <div class="position-relative z-1 mt-5 mb-auto" style="max-width: 32rem;">
            <h1 class="font-display fw-bold text-white mb-4" style="font-size: 3.5rem; line-height: 1.1;">
                Streamline your<br/>workflow.
            </h1>
            <p class="fs-5 text-white-50 fw-light" style="line-height: 1.6;">
                Velocity removes the friction of task tracking with an exceptionally clean, spacious interface that highlights progress and blocks out noise.
            </p>
        </div>
        
        <!-- Bottom Carousel Indicators -->
        <div class="position-relative z-1 d-flex gap-2 pb-3">
            <div class="bg-white rounded-pill" style="width: 32px; height: 4px;"></div>
            <div class="rounded-pill" style="width: 4px; height: 4px; background-color: rgba(255, 255, 255, 0.5);"></div>
            <div class="rounded-pill" style="width: 4px; height: 4px; background-color: rgba(255, 255, 255, 0.5);"></div>
        </div>
    </section>

    <!-- Right Panel -->
    <section class="flex-grow-1 d-flex align-items-center justify-content-center p-4 p-sm-5 position-relative" style="background-color: #fafafa;">
        
        <!-- Login Card -->
        <div class="w-100 bg-white rounded-4 shadow-lg position-relative z-1 p-4 p-sm-5" style="max-width: 28rem;">
            <div class="mb-4">
                <h2 class="fs-2 fw-bold text-dark mb-2">Welcome back</h2>
                <p class="text-muted small">Enter your details to access your account.</p>
            </div>

            <!-- Social Login Buttons -->
            <div class="d-flex flex-column gap-2 mb-4">
                <button type="button" class="btn btn-outline-secondary d-flex align-items-center justify-content-center w-100 py-2 border-1" style="background-color: white;">
                    <svg class="me-2" style="width: 20px; height: 20px;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.16v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.16C1.43 8.55 1 10.22 1 12s.43 3.45 1.16 4.93l3.68-2.84z" fill="#FBBC05"></path>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.16 7.07l3.68 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
                    </svg>
                    <span class="fs-6 fw-medium text-dark">Sign in with Google</span>
                </button>
                <button type="button" class="btn btn-outline-secondary d-flex align-items-center justify-content-center w-100 py-2 border-1" style="background-color: white;">
                    <svg class="me-2 text-dark" style="width: 20px; height: 20px;" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
                    </svg>
                    <span class="fs-6 fw-medium text-dark">Sign in with Github</span>
                </button>
            </div>

            <!-- Form -->
            <form asp-action="Login" asp-Controller="Account" class="d-flex flex-column gap-3" method="POST">
                @Html.AntiForgeryToken()
                <div  class="text-danger"></div>

                <!-- Email Field -->
                <div>
                    <div class="input-auth-field rounded-3 d-flex align-items-center px-3 py-2">
                        
                        <input type="email" class="form-control bg-transparent border-0 shadow-none p-0 text-dark" id="email" asp-for="Email" placeholder="Email Address" required />

                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>

                </div>

                <!-- Password Field -->
                <div>
                    <div class="input-auth-field rounded-3 d-flex align-items-center px-3 py-2">
                        <input type="password" class="form-control bg-transparent border-0 shadow-none p-0 text-dark" id="password" asp-for="Password" placeholder="Password" required />

                        <button type="button" class="btn btn-link text-muted p-0 ms-2 text-decoration-none shadow-none">
                            <i class="fa-solid fa-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>

                </div>

                <!-- Options Row -->
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="remember-me" asp-for="RememberMe">
                        <label class="form-check-label text-dark small" for="remember-me">
                            Remember me
                        </label>
                    </div>
                    <div>
                        <a href="#" class="text-decoration-none fw-medium small" style="color: #6366f1;">Forgot password?</a>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="mt-3">
                    <button type="submit" class="btn w-100 rounded-pill text-white fw-medium py-2 shadow-sm" style="background-color: #6366f1;">
                        Sign In
                    </button>
                </div>
            </form>

            <!-- Sign Up Link -->
            <p class="text-center text-muted small mt-4 mb-0">
                Don't have an account? 
                <a asp-action="Register" asp-controller="Account" class="text-decoration-none fw-medium ms-1" style="color: #6366f1;">Create Account</a>
            </p>
        </div>
    </section>
</main>
