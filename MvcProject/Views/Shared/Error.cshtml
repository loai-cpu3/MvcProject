@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_AppLayout";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
            <span class="material-symbols-outlined text-danger" style="font-size: 40px;">error_outline</span>
        </div>
        <h1 class="font-display fw-bold text-dark fs-3 mb-2">Something went wrong</h1>
        <p class="text-muted-light mb-4" style="max-width: 420px; margin: 0 auto;">
            An unexpected error occurred while processing your request. Please try again or contact support if the issue persists.
        </p>

        @if (Model?.ShowRequestId == true)
        {
            <div class="d-inline-block bg-light rounded-3 px-3 py-2 mb-4">
                <span class="text-muted-light extra-small fw-semibold">Request ID:</span>
                <code class="text-dark extra-small ms-1">@Model.RequestId</code>
            </div>
        }

        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold shadow-sm d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-6">home</span>
                Go to Dashboard
            </a>
            <button onclick="history.back()" class="btn btn-light border border-border-light rounded-pill px-4 py-2 fw-semibold shadow-sm d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-6">arrow_back</span>
                Go Back
            </button>
        </div>
    </div>
</div>
