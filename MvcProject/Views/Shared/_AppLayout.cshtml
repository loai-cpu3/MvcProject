@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Velocity Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-row vh-100 overflow-hidden">

    
    <aside class="sidebar-width bg-surface-light border-end border-border-light d-flex flex-column z-index-20">
        <div class="d-flex align-items-center px-4 border-bottom border-border-light" style="height: 64px;">
            <div class="d-flex align-items-center gap-3 w-100">
                <div class="rounded p-2 d-flex align-items-center justify-content-center" style="background-color: #6366f1;">
                    <span class="material-symbols-outlined text-primary fs-5">view_kanban</span>
                </div>
                <div class="d-flex flex-column">
                    <h1 class="font-display fw-bold mb-0 text-dark" style="font-size: 1rem; line-height: 1.2;">Velocity</h1>
                    <span class="text-muted-light fw-medium" style="font-size: 0.75rem;">Product Team</span>
                </div>
            </div>
        </div>
        
        <nav class="d-flex flex-column flex-grow-1 py-4 px-3 gap-1 overflow-auto">
            <a class="nav-link-custom d-flex align-items-center gap-3 px-3 py-2 rounded font-display fw-semibold text-decoration-none shadow-none @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Dashboard">
                <span class="material-symbols-outlined fs-5">dashboard</span>
                <span class="fs-6">Dashboard</span>
            </a>
            <a class="nav-link-custom d-flex align-items-center gap-3 px-3 py-2 rounded font-display fw-semibold text-decoration-none shadow-none @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Projects" ? "active" : "")" asp-controller="Projects" asp-action="Index">
                <span class="material-symbols-outlined fs-5">folder_open</span>
                <span class="fs-6">Projects</span>
            </a>
            <a class="nav-link-custom d-flex align-items-center gap-3 px-3 py-2 rounded font-display fw-semibold text-decoration-none shadow-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "AllTasks" ? "active" : "")" asp-controller="ProjectTask" asp-action="AllTasks">
                <span class="material-symbols-outlined fs-5">task_alt</span>
                <span class="fs-6">Tasks</span>
            </a>
            <a class="nav-link-custom d-flex align-items-center gap-3 px-3 py-2 rounded font-display fw-semibold text-decoration-none shadow-none @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Team" ? "active" : "")" asp-controller="Team" asp-action="Index">
                <span class="material-symbols-outlined fs-5">group</span>
                <span class="fs-6">Team</span>
            </a>
        </nav>

        <div class="p-3 border-top border-border-light">
            <a class="nav-link-custom d-flex align-items-center gap-3 px-3 py-2 rounded font-display fw-semibold text-decoration-none shadow-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "active" : "")" asp-controller="Account" asp-action="Settings">
                <span class="material-symbols-outlined fs-5">settings</span>
                <span class="fs-6">Settings</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="d-flex flex-column flex-grow-1 w-100 h-100 overflow-hidden">
        
        <!-- Top Navbar -->
        <header class="d-flex align-items-center justify-content-between px-3 px-sm-4 bg-surface-light border-bottom border-border-light sticky-top z-index-10" style="height: 64px;">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link text-muted-light d-md-none p-1 text-decoration-none border-0 shadow-none">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                @* <div class="position-relative d-none d-sm-flex" style="width: 250px;">
                    <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted-light fs-5" style="left: 12px;">search</span>
                    <input type="text" class="form-control bg-light border-0 rounded-3 shadow-none text-dark" style="padding-left: 40px; font-size: 0.875rem;" placeholder="Search everywhere..." />
                </div> *@
            </div>

            <div class="d-flex align-items-center gap-2 gap-sm-3">
                @* <button class="btn btn-link p-2 text-muted-light position-relative rounded-circle d-flex align-items-center justify-content-center text-decoration-none border-0 shadow-none hover-bg-light">
                     <span class="material-symbols-outlined">notifications</span> 
                    <span class="position-absolute rounded-circle bg-danger border border-white" style="width: 8px; height: 8px; top: 6px; right: 6px;"></span>
                </button> *@
                @* <div class="ms-1 border border-2 border-white shadow-sm overflow-hidden" style="width: 32px; height: 32px; border-radius: 50%; cursor: pointer;">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBfanUbcrhevPueAU9SDuQ2k-054rYQd_P0AQg_N81Iv-G5sSgoZVyABcYvPM6hsbxwh2oxfU7DwnCkDlAjmkQ7U0bY2cxXmyTFZBpxOtRRvAlnsDaijhIjPzDKbYcZVXgv-MnNd7IiS6YC5z5ijuxF-twMZfroLXJ-KP2un4YRyN0WnOCuQOwXaQnIThJvkVspYsfHCbhLDauR1sGtMeKcM8fDYb6Mxh_ifn_jCEwtrWjxzDt-kGtuGqMEm6k1eRV41xx1eIHsW6Jb" alt="User profile" style="width: 100%; height: 100%; object-fit: cover;" />
                </div> *@
            </div>
            @if (@User.Identity.IsAuthenticated)
            {


                <div class="d-flex align-items-center gap-2 gap-sm-3">
                    <!-- Notification Bell Dropdown -->
                    <div class="dropdown" id="notification-dropdown">
                        <button class="btn btn-link p-2 text-muted-light position-relative rounded-circle d-flex align-items-center justify-content-center text-decoration-none border-0 shadow-none hover-bg-light"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="notification-bell">
                            <span class="material-symbols-outlined">notifications</span>
                            <span class="position-absolute rounded-pill bg-danger text-white d-flex align-items-center justify-content-center"
                                  style="min-width: 18px; height: 18px; font-size: 0.65rem; top: 2px; right: 2px; padding: 0 4px; display: none !important;"
                                  id="notification-badge">0</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 p-0" style="width: 360px; max-height: 420px; overflow: hidden; border-radius: 12px;">
                            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                                <span class="fw-bold text-white small">Notifications</span>
                                <button class="btn btn-link btn-sm text-white text-decoration-none p-0" style="font-size: 0.75rem;" id="mark-all-read-btn">
                                    Mark all as read
                                </button>
                            </div>
                            <div id="notification-list" style="max-height: 340px; overflow-y: auto;">
                                <div class="text-center text-muted py-4" id="notification-empty">
                                    <span class="material-symbols-outlined d-block mb-1" style="font-size: 32px; opacity: 0.4;">notifications_off</span>
                                    <span class="small">No new notifications</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @inject UserManager<MvcProject.Models.Domain.ApplicationUser> UserManager
                    @{
                        var currentUser = await UserManager.GetUserAsync(User);
                    }

                    <div class="dropdown">
                        <div class="ms-1 border border-2 border-white shadow-sm overflow-hidden"
                             style="width: 32px; height: 32px; border-radius: 50%; cursor: pointer;"
                             data-bs-toggle="dropdown"
                             aria-expanded="false">

                            @if (!string.IsNullOrEmpty(currentUser?.ProfilePictureUrl))
                            {
                        
                                <img src="@currentUser.ProfilePictureUrl" alt="Profile"
                                     style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                               
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="background-color: #6366f1; font-size: 0.8rem;">
                                    @currentUser?.FirstName?.Substring(0, 1).ToUpper()
                                </div>
                            }

                        </div>

                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li class="px-3 py-2">
                                <p class="mb-0 fw-semibold text-dark small">
                                    @currentUser?.FirstName @currentUser?.LastName
                                </p>
                                <p class="mb-0 text-muted" style="font-size: 11px;">
                                    @currentUser?.Email
                                </p>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <form asp-action="Logout" asp-controller="Account" method="POST">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item small text-danger">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                
                </div>
            }
            else
            {
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Account" asp-action="Login"
                           class="btn btn-outline-secondary rounded-pill px-3 py-1"
                           style="font-size: 0.875rem;">
                        Login
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                           class="btn btn-primary rounded-pill px-3 py-1"
                           style="font-size: 0.875rem; background-color: #6366f1; border-color: #6366f1;">
                        Register
                    </a>
                </div>
            }
        </header>

        <!-- Page Content -->
        <main class="flex-grow-1 overflow-auto p-3 p-sm-4 bg-background-light">
            @RenderBody()
        </main>
    </div>

    <style>
        .notif-item {
            transition: background-color 0.2s ease;
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
        }
        .notif-item:hover {
            background-color: #f8f8ff;
        }
        .notif-item:last-child {
            border-bottom: none;
        }
        .notif-new {
            animation: notifSlideIn 0.3s ease;
        }
        @@keyframes notifSlideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/microsoft-signalr/dist/browser/signalr.min.js"></script>

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            (function () {
                const badge = document.getElementById('notification-badge');
                const list = document.getElementById('notification-list');
                const emptyMsg = document.getElementById('notification-empty');
                const markAllBtn = document.getElementById('mark-all-read-btn');
                const bell = document.getElementById('notification-bell');

                let notificationsLoaded = false;

                function updateBadge(count) {
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.style.cssText = 'min-width: 18px; height: 18px; font-size: 0.65rem; top: 2px; right: 2px; padding: 0 4px;';
                    } else {
                        badge.style.cssText = 'display: none !important;';
                    }
                }

                function getNotifUrl(notif) {
                    if (notif.relatedEntityType === 'ProjectTask') {
                        const pid = notif.projectId || 0;
                        return '/ProjectTask/Detail/' + notif.relatedEntityId + '?projectId=' + pid;
                    }
                    if (notif.relatedEntityType === 'Project') {
                        return '/Projects/Details?projectId=' + notif.relatedEntityId;
                    }
                    return '#';
                }

                function getNotifIcon(type) {
                    if (type === 'CommentAdded') return 'chat_bubble';
                    if (type === 'ProjectMemberAdded') return 'group_add';
                    if (type === 'TaskAssigned') return 'task_alt';
                    return 'notifications';
                }

                function getNotifColor(type) {
                    if (type === 'CommentAdded') return '#3b82f6';
                    if (type === 'ProjectMemberAdded') return '#8b5cf6';
                    if (type === 'TaskAssigned') return '#10b981';
                    return '#6b7280';
                }

                function formatTimeAgo(dateStr) {
                    const d = new Date(dateStr);
                    const now = new Date();
                    const s = Math.floor((now - d) / 1000);
                    if (s < 60) return 'just now';
                    const m = Math.floor(s / 60);
                    if (m < 60) return m + 'm ago';
                    const h = Math.floor(m / 60);
                    if (h < 24) return h + 'h ago';
                    const days = Math.floor(h / 24);
                    return days + 'd ago';
                }

                function createNotifHtml(n, isNew) {
                    const icon = getNotifIcon(n.type);
                    const color = getNotifColor(n.type);
                    const url = getNotifUrl(n);
                    const cls = isNew ? ' notif-new' : '';
                    return `<a href="${url}" class="notif-item d-flex gap-3 px-3 py-3 text-decoration-none${cls}" data-notif-id="${n.id}">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background-color: ${color}20;">
                            <span class="material-symbols-outlined" style="font-size: 18px; color: ${color};">${icon}</span>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 text-dark small" style="line-height: 1.4;">${n.content}</p>
                            <span class="text-muted" style="font-size: 0.7rem;">${formatTimeAgo(n.createdAt)}</span>
                        </div>
                    </a>`;
                }

                // Load unread count on page load
                async function loadCount() {
                    try {
                        const res = await fetch('/api/Notification/count');
                        if (!res.ok) return;
                        const data = await res.json();
                        updateBadge(data.count);
                    } catch (e) { console.warn('Notification count error:', e); }
                }

                // Load notifications when dropdown opens
                async function loadNotifications() {
                    try {
                        const res = await fetch('/api/Notification');
                        if (!res.ok) return;
                        const notifs = await res.json();
                        if (notifs.length === 0) {
                            emptyMsg.style.display = '';
                            return;
                        }
                        emptyMsg.style.display = 'none';
                        list.innerHTML = '';
                        notifs.forEach(n => {
                            list.insertAdjacentHTML('beforeend', createNotifHtml(n, false));
                        });
                        notificationsLoaded = true;
                    } catch (e) { console.warn('Notification load error:', e); }
                }

                // Open dropdown → load notifications
                bell.addEventListener('click', () => {
                    loadNotifications();
                });

                // Mark all as read
                markAllBtn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    try {
                        await fetch('/api/Notification/read-all', { method: 'POST' });
                        updateBadge(0);
                        list.innerHTML = '';
                        emptyMsg.style.display = '';
                        list.appendChild(emptyMsg);
                    } catch (e) { console.warn('Mark all read error:', e); }
                });

                // Click a notification → mark as read
                list.addEventListener('click', async (e) => {
                    const item = e.target.closest('.notif-item');
                    if (!item) return;
                    const id = item.dataset.notifId;
                    if (id) {
                        fetch('/api/Notification/' + id + '/read', { method: 'POST' }).catch(() => {});
                    }
                });

                // SignalR
                async function initNotificationHub() {
                    if (typeof signalR === 'undefined') return;

                    const conn = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/notification')
                        .withAutomaticReconnect()
                        .build();

                    conn.on('ReceiveNotification', (notif) => {
                        // Update badge
                        if (notif.unreadCount !== undefined) {
                            updateBadge(notif.unreadCount);
                        } else {
                            const current = parseInt(badge.textContent) || 0;
                            updateBadge(current + 1);
                        }

                        // Prepend to list if open
                        emptyMsg.style.display = 'none';
                        list.insertAdjacentHTML('afterbegin', createNotifHtml(notif, true));
                    });

                    try {
                        await conn.start();
                    } catch (err) {
                        console.warn('Notification hub error:', err);
                        setTimeout(initNotificationHub, 5000);
                    }
                }

                loadCount();
                initNotificationHub();
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

