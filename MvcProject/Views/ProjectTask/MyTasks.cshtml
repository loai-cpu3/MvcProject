@model MvcProject.ViewModels.ProjectTask.UserTasksViewModel
@{
    ViewData["Title"] = "My Tasks";
}

<div class="mx-auto pb-5" style="max-width: 1200px;">
    <div class="mb-4">
        <h2 class="font-display fw-bold fs-3 text-dark tracking-tight mb-1">Tasks Explorer</h2>
        <p class="text-muted-light small mb-0">View and manage tasks across all your projects. Use filters to narrow down your search.</p>
    </div>

    <!-- Filter Section -->
    <div class="bg-surface-light p-4 rounded-4 shadow-soft border border-border-light mb-4">
        <form asp-controller="ProjectTask" asp-action="MyTasks" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="projectId" class="form-label small fw-semibold text-muted-light ps-1">Project</label>
                <select name="projectId" id="projectId" class="form-select border-border-light bg-light shadow-xs" asp-items="Model.ProjectList">
                    <option value="">All Projects</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="status" class="form-label small fw-semibold text-muted-light ps-1">Status</label>
                <select name="status" id="status" class="form-select border-border-light bg-light shadow-xs" asp-items="Model.StatusList">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 fw-semibold shadow-sm d-flex align-items-center gap-2 flex-grow-1 justify-content-center">
                    <span class="material-symbols-outlined" style="font-size: 20px;">filter_alt</span>
                    Apply Filters
                </button>
                @if (Model.SelectedProjectId.HasValue || Model.SelectedStatus.HasValue)
                {
                    <a asp-controller="ProjectTask" asp-action="MyTasks" class="btn btn-outline-secondary px-3 shadow-sm d-flex align-items-center justify-content-center" title="Clear Filters">
                        <span class="material-symbols-outlined" style="font-size: 20px;">filter_alt_off</span>
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="d-flex flex-column gap-5">
        <!-- To Do Section -->
        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle bg-secondary" style="width: 8px; height: 8px;"></span>
                    To Do
                    <span class="text-muted-light fw-normal small ms-1">@Model.ToDoTasks.Count</span>
                </h3>
            </div>
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light overflow-hidden">
                @if (Model.ToDoTasks.Any())
                {
                    <div class="task-list">
                        @foreach (var task in Model.ToDoTasks)
                        {
                            @await Html.PartialAsync("_TaskRow", task)
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted-light small italic">No tasks in this category.</div>
                }
            </div>
        </div>

        <!-- In Progress Section -->
        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle bg-primary" style="width: 8px; height: 8px;"></span>
                    In Progress
                    <span class="text-muted-light fw-normal small ms-1">@Model.InProgressTasks.Count</span>
                </h3>
            </div>
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light overflow-hidden">
                @if (Model.InProgressTasks.Any())
                {
                    <div class="task-list">
                        @foreach (var task in Model.InProgressTasks)
                        {
                            @await Html.PartialAsync("_TaskRow", task)
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted-light small italic">No tasks in progress.</div>
                }
            </div>
        </div>

        <!-- Review Section -->
        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle" style="width: 8px; height: 8px; background-color: #A855F7;"></span>
                    Review
                    <span class="text-muted-light fw-normal small ms-1">@Model.ReviewTasks.Count</span>
                </h3>
            </div>
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light overflow-hidden">
                @if (Model.ReviewTasks.Any())
                {
                    <div class="task-list">
                        @foreach (var task in Model.ReviewTasks)
                        {
                            @await Html.PartialAsync("_TaskRow", task)
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted-light small italic">No tasks in review.</div>
                }
            </div>
        </div>

        <!-- Done Section -->
        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle" style="width: 8px; height: 8px; background-color: #10B981;"></span>
                    Done
                    <span class="text-muted-light fw-normal small ms-1">@Model.DoneTasks.Count</span>
                </h3>
            </div>
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light overflow-hidden">
                @if (Model.DoneTasks.Any())
                {
                    <div class="task-list">
                        @foreach (var task in Model.DoneTasks)
                        {
                            @await Html.PartialAsync("_TaskRow", task)
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted-light small italic">No completed tasks.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .task-row:hover { background-color: #F9FAFB !important; }
        .task-row:hover .fw-bold { color: var(--bs-primary) !important; }
        .extra-small { font-size: 0.75rem; }
    </style>
}

<style>
    .task-row:hover {
        background-color: #F9FAFB !important;
    }
    .task-row:hover .fw-bold {
        color: var(--bs-primary) !important;
    }
    .extra-small {
        font-size: 0.75rem;
    }
    .shadow-soft {
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    }
    .shadow-xs {
        box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    }
</style>
