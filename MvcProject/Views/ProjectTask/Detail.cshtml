@model MvcProject.ViewModels.ProjectTask.ProjectTaskDetailViewModel
@using MvcProject.Models.Enums

@{
    ViewData["Title"] = $"Task: {Model.Title}";
    
    var statusClass = Model.Status switch
    {
        MvcProject.Models.Enums.TaskStatus.ToDo => "bg-secondary",
        MvcProject.Models.Enums.TaskStatus.InProgress => "bg-primary",
        MvcProject.Models.Enums.TaskStatus.Review => "bg-info",
        MvcProject.Models.Enums.TaskStatus.Done => "bg-success",
        _ => "bg-secondary"
    };

    var priorityClass = Model.Priority switch
    {
        TaskPriority.Low => "bg-info-light text-info",
        TaskPriority.Medium => "bg-warning-light text-warning-dark",
        TaskPriority.High => "bg-danger-light text-danger",
        _ => "bg-light text-muted"
    };
}

<div class="container-fluid py-4 h-100 overflow-auto">
    <!-- Header -->
    <div class="row align-items-center mb-4">
        <div class="col-auto">
            <a asp-controller="Projects" asp-action="Details" asp-route-projectId="@Model.ProjectId" class="btn btn-icon btn-light rounded-circle shadow-sm">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
        </div>
        <div class="col ms-2">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index" class="text-decoration-none text-muted">Projects</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Details" asp-route-projectId="@Model.ProjectId" class="text-decoration-none text-muted">@Model.ProjectTitle</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Task Detail</li>
                </ol>
            </nav>
            <h1 class="h3 font-display fw-bold text-dark mb-0">@Model.Title</h1>
        </div>
        @if (Model.CanEditDelete)
        {
            <div class="col-auto d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-projectId="@Model.ProjectId" class="btn btn-outline-primary d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined fs-5">edit</span>
                    Edit
                </a>
                <button type="button" class="btn btn-outline-danger d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <span class="material-symbols-outlined fs-5">delete</span>
                    Delete
                </button>
            </div>
        }
    </div>

    <div class="row g-4">
        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-3">Description</h5>
                    <div class="text-muted lh-lg">
                        @if (string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <em class="text-muted-light">No description provided for this task.</em>
                        }
                        else
                        {
                            @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                        }
                    </div>
                </div>
            </div>

            <!-- Attachments -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold text-dark mb-0">Attachments</h5>
                    <span class="badge bg-light text-muted fw-normal">@Model.Attachments.Count Files</span>
                </div>
                <div class="card-body p-4">
                    @if (!Model.Attachments.Any())
                    {
                        <div class="text-center py-4 bg-light rounded-3 border border-dashed">
                            <span class="material-symbols-outlined fs-1 text-muted-light mb-2">attachment</span>
                            <p class="text-muted small mb-0">No attachments found</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush border-top">
                            @foreach (var file in Model.Attachments)
                            {
                                <div class="list-group-item px-0 py-3 d-flex align-items-center justify-content-between border-border-light">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary-light rounded-3 p-2 d-flex align-items-center justify-content-center">
                                            <span class="material-symbols-outlined text-primary">description</span>
                                        </div>
                                        <div>
                                            <p class="fw-semibold text-dark mb-0 small">@file.FileName</p>
                                            <span class="text-muted-light small">@((file.Size / 1024d / 1024d).ToString("F2")) MB • @file.UploadedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                    <a asp-action="DownloadAttachment" asp-route-id="@file.Id" asp-route-projectId="@Model.ProjectId" class="btn btn-icon btn-light rounded-circle shadow-sm" title="Download">
                                        <span class="material-symbols-outlined">download</span>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar Details -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-4">Attributes</h5>
                    
                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Status</label>
                        <span class="badge @statusClass py-2 px-3 rounded-pill fw-medium fs-7">@Model.Status</span>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Priority</label>
                        <span class="badge @priorityClass py-2 px-3 rounded-pill fw-medium fs-7">@Model.Priority</span>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase mb-2 d-block">Deadline</label>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-muted fs-5">calendar_today</span>
                            <span class="@(Model.Deadline < DateTime.Now && Model.Status != MvcProject.Models.Enums.TaskStatus.Done ? "text-danger fw-bold" : "text-dark")">
                                @(Model.Deadline?.ToString("MMM dd, yyyy") ?? "No Deadline")
                            </span>
                        </div>
                    </div>

                    <hr class="my-4 border-border-light" />

                    <div>
                        <label class="text-muted small fw-bold text-uppercase mb-3 d-block">Assignee</label>
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(Model.AssigneePhotoUrl))
                            {
                                <img src="@Model.AssigneePhotoUrl" alt="@Model.AssigneeName" class="rounded-circle border border-2 border-primary-light" style="width: 48px; height: 48px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="rounded-circle bg-light border border-2 border-dashed d-flex align-items-center justify-content-center text-muted" style="width: 48px; height: 48px;">
                                    <span class="material-symbols-outlined">person</span>
                                </div>
                            }
                            <div>
                                <h6 class="fw-bold text-dark mb-0">@Model.AssigneeName</h6>
                                <span class="text-muted small">Assigned Member</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.CanEditDelete)
{
    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold text-dark" id="deleteModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted mb-0">Are you sure you want to delete the task <strong>"@Model.Title"</strong>? This action cannot be undone and will also delete all attachments.</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" asp-route-id="@Model.Id" asp-route-projectId="@Model.ProjectId" method="post">
                        <button type="submit" class="btn btn-danger px-4">Delete Task</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .bg-info-light { background-color: #E0F2FE; }
    .bg-warning-light { background-color: #FEF3C7; }
    .bg-danger-light { background-color: #FEE2E2; }
    .bg-primary-light { background-color: #E0E7FF; }
    .bg-success-light { background-color: #DCFCE7; }
    .text-warning-dark { color: #92400E; }
    .fs-7 { font-size: 0.85rem; }
    .btn-icon { width: 38px; height: 38px; padding: 0; display: inline-flex; align-items: center; justify-content: center; }
</style>
