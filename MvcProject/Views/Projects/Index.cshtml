@model MvcProject.ViewModels.Projects.ProjectIndexViewModel
@{
    ViewData["Title"] = "Projects";
}

<div class="mx-auto pb-5" style="max-width: 1200px;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="font-display fw-bold fs-4 text-dark tracking-tight mb-0">Projects</h2>
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 rounded-3 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#createProjectModal">
            <span class="material-symbols-outlined fs-6">add</span>
            New Project
        </button>
    </div>

    @if (Model.Projects.Any())
    {
        <div class="row g-4">
            @foreach (var project in Model.Projects)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="Projects" asp-action="Details" asp-route-projectId="@project.ProjectId" class="text-decoration-none">
                        <div class="bg-surface-light rounded-3 p-4 border border-border-light shadow-soft d-flex flex-column h-100" style="min-height: 200px; cursor: pointer;">
                            <h3 class="font-display fw-semibold fs-6 mb-2 text-truncate text-dark">@project.Title</h3>
                            <p class="small text-muted-light mb-auto" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@project.Description</p>

                            <div class="mt-4 d-flex flex-column gap-2">
                                <span class="fw-medium text-dark" style="font-size: 12px;">@project.CompletionPercentage%</span>
                                <div class="progress w-100 bg-border-light rounded-pill" style="height: 6px;">
                                    <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: @project.CompletionPercentage%;" aria-valuenow="@project.CompletionPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-surface-light rounded-3 p-4 border border-border-light shadow-soft text-muted-light">
            No projects assigned to you yet.
        </div>
    }
</div>

<div class="modal fade" id="createProjectModal" tabindex="-1" aria-labelledby="createProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-soft rounded-4">
            <div class="modal-header border-bottom border-border-light">
                <h5 class="modal-title font-display fw-bold text-dark" id="createProjectModalLabel">Create New Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Projects" asp-action="CreateProject" method="post">
                <div class="modal-body d-flex flex-column gap-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div>
                        <label asp-for="CreateProject.Title" class="form-label fw-semibold text-dark"></label>
                        <input asp-for="CreateProject.Title" name="Title" class="form-control" />
                        <span class="text-danger small" data-valmsg-for="Title" data-valmsg-replace="true"></span>
                    </div>

                    <div>
                        <label asp-for="CreateProject.Description" class="form-label fw-semibold text-dark"></label>
                        <textarea asp-for="CreateProject.Description" name="Description" class="form-control" rows="4"></textarea>
                        <span class="text-danger small" data-valmsg-for="Description" data-valmsg-replace="true"></span>
                    </div>
                </div>
                <div class="modal-footer border-top border-border-light">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Project</button>
                </div>
            </form>
        </div>
    </div>
</div>
