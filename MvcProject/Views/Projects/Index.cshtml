@model MvcProject.ViewModels.Projects.CreateProjectViewModel
@{
    ViewData["Title"] = "Projects";
}

<div class="mx-auto pb-5" style="max-width: 1200px;">
    <!-- Page Header & Actions -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="font-display fw-bold fs-4 text-dark tracking-tight mb-0">Projects</h2>
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 rounded-3 border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#createProjectModal">
            <span class="material-symbols-outlined fs-6">add</span>
            New Project
        </button>
    </div>

    <!-- Projects Grid -->
    <div class="row g-4">
        <!-- Card 1 (In Progress) -->
        <div class="col-12 col-md-6 col-lg-4 col-xl-3">
            <div class="bg-surface-light rounded-3 p-4 border border-border-light shadow-soft hover-shadow transition-all d-flex flex-column h-100" style="min-height: 200px; cursor: pointer;">
