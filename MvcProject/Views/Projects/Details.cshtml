@model MvcProject.ViewModels.Projects.ProjectDetailsViewModel
@{
    ViewData["Title"] = "Project Details";
}

<div class="mx-auto pb-5" style="max-width: 1200px;">
    <!-- Project Header -->
    <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center gap-3 mb-2">
                <h1 class="fs-3 fs-sm-2 font-display fw-bold text-dark mb-0 tracking-tight">@Model.Title</h1>
                <span class="badge rounded-pill fw-semibold" style="background-color: #FEF3C7; color: #92400E;">@Model.CompletionPercentage%</span>
            </div>
            <p class="text-muted-light small mb-0" style="max-width: 42rem;">
                @Model.Description
            </p>
        </div>
        
        <div class="d-flex align-items-center gap-2 align-self-start">
            <div class="d-none d-sm-flex align-items-center me-2">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAx4DjjP-gqLBNa_JyURjDJdEaWBCnmTVrk76upE7cD3pRhNHMdSLWKkH60D5Erd0vToZddqm88_BIl1cYR4HbbdWA6f2HaOAGC70mXape7LJmx_yNiBVQkhjX8-uLQpAsmNgSoRFUKOm0hGjTd633nvrqpKDo6H-PZzuzMljkXIVOZwZunhclSz8z2KI21XHfSnejud2O9M0P_yCFszN0LFq_opAqj8LQuy2SAFCxFtyhIF7S7mmi9ZF0uOtC6TXLheEgodEBV7v2j" alt="Team member" class="rounded-circle border border-2 border-white object-fit-cover" style="width: 32px; height: 32px; z-index: 3;">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCU_4K8R15USDca_tYDCPrOylUfjUhpDzSxOdwqdhCw-GSEjFTof9E0ADecoAvM90ktMwrmZQLjTrORgHIWHHnZ6Lxi4nVy_Kzk8jwxVwI9WTy27byfKKhe5snFSHf9xBGAx-N_VDp8bmoDj41GI_eINdpnOQVowaQ26nn6XmaF3ccm25-W-V2EJ1CtVGQJigX1fdADGPrADwZnActTpLC9PZbxNN6DfN3qqL0YBhXkRj1qjVwbbrBShh4wLSrWl0-BZryJvwf-Jpmw" alt="Team member" class="rounded-circle border border-2 border-white object-fit-cover" style="width: 32px; height: 32px; margin-left: -8px; z-index: 2;">
                <div class="rounded-circle border border-2 border-white bg-light d-flex align-items-center justify-content-center text-muted fw-medium" style="width: 32px; height: 32px; margin-left: -8px; font-size: 12px; z-index: 1;">+3</div>
            </div>
            <a asp-controller="ProjectTask" asp-action="Create" asp-route-projectId="@Model.ProjectId" class="btn btn-primary fw-semibold font-display shadow-sm" style="font-size: 0.875rem;">
                Create Task
            </a>
            <button type="button" class="btn btn-light bg-surface-light border-border-light text-dark fw-semibold font-display shadow-sm" style="font-size: 0.875rem;" data-bs-toggle="modal" data-bs-target="#editProjectModal">
                Edit Project
            </button>
            <button type="button" class="btn btn-danger fw-semibold font-display shadow-sm" style="font-size: 0.875rem;" data-bs-toggle="modal" data-bs-target="#deleteProjectModal">
                Delete Project
            </button>
        </div>
    </div>

    <div class="bg-surface-light rounded-3 border border-border-light p-3 p-sm-4 shadow-soft mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="small text-muted-light">Task Completion</span>
            <span class="small fw-semibold text-dark">@Model.CompletedTasks / @Model.TotalTasks</span>
        </div>
        <div class="progress w-100 bg-border-light rounded-pill" style="height: 6px;">
            <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: @Model.CompletionPercentage%;" aria-valuenow="@Model.CompletionPercentage" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>

<div class="modal fade" id="editProjectModal" tabindex="-1" aria-labelledby="editProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-soft rounded-4">
            <div class="modal-header border-bottom border-border-light">
                <h5 class="modal-title font-display fw-bold text-dark" id="editProjectModalLabel">Edit Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Projects" asp-action="EditProject" asp-route-projectId="@Model.ProjectId" method="post">
                <input type="hidden" asp-for="EditProject.Id" />

                <div class="modal-body d-flex flex-column gap-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div>
                        <label asp-for="EditProject.Title" class="form-label fw-semibold text-dark"></label>
                        <input asp-for="EditProject.Title" class="form-control" />
                        <span asp-validation-for="EditProject.Title" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="EditProject.Description" class="form-label fw-semibold text-dark"></label>
                        <textarea asp-for="EditProject.Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="EditProject.Description" class="text-danger small"></span>
                    </div>
                </div>

                <div class="modal-footer border-top border-border-light">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteProjectModal" tabindex="-1" aria-labelledby="deleteProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-soft rounded-4">
            <div class="modal-header border-bottom border-border-light">
                <h5 class="modal-title font-display fw-bold text-dark" id="deleteProjectModalLabel">Delete Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-0 text-muted-light">Are you sure you want to delete this project? This action cannot be undone.</p>
            </div>

            <div class="modal-footer border-top border-border-light">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <form asp-controller="Projects" asp-action="DeleteProject" asp-route-projectId="@Model.ProjectId" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

    <!-- Tab Navigation -->
    <div class="border-bottom border-border-light mb-4">
        <ul class="nav nav-tabs border-bottom-0 flex-nowrap overflow-auto pb-0" style="gap: 2rem;">
            <li class="nav-item">
                <a class="nav-link active rounded-0 border-top-0 border-start-0 border-end-0 border-bottom border-2 border-primary text-primary fw-semibold font-display px-1 py-3" href="#">Tasks</a>
            </li>
            <li class="nav-item">
                <a class="nav-link rounded-0 border-top-0 border-start-0 border-end-0 border-bottom border-2 border-transparent text-muted-light fw-medium font-display px-1 py-3 hover-text-dark" href="#">Board</a>
            </li>
            <li class="nav-item">
                <a class="nav-link rounded-0 border-top-0 border-start-0 border-end-0 border-bottom border-2 border-transparent text-muted-light fw-medium font-display px-1 py-3 hover-text-dark d-flex align-items-center" href="#">
                    Files
                    <span class="badge bg-light text-muted-light ms-2 rounded-pill fw-normal">4</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link rounded-0 border-top-0 border-start-0 border-end-0 border-bottom border-2 border-transparent text-muted-light fw-medium font-display px-1 py-3 hover-text-dark" href="#">Settings</a>
            </li>
        </ul>
    </div>

    <!-- Tab Content: Tasks -->
    <div class="d-flex flex-column gap-4">
        
        @foreach (var status in Enum.GetValues(typeof(MvcProject.Models.Enums.TaskStatus)).Cast<MvcProject.Models.Enums.TaskStatus>())
        {
            var statusTasks = Model.Tasks.Where(t => t.Status == status).ToList();
            if (statusTasks.Any())
            {
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                            @{
                                var dotColor = status switch
                                {
                                    MvcProject.Models.Enums.TaskStatus.ToDo => "bg-secondary",
                                    MvcProject.Models.Enums.TaskStatus.InProgress => "bg-primary",
                                    MvcProject.Models.Enums.TaskStatus.Review => "bg-info",
                                    MvcProject.Models.Enums.TaskStatus.Done => "bg-success",
                                    _ => "bg-secondary"
                                };
                                var statusName = status switch
                                {
                                    MvcProject.Models.Enums.TaskStatus.ToDo => "To Do",
                                    MvcProject.Models.Enums.TaskStatus.InProgress => "In Progress",
                                    _ => status.ToString()
                                };
                            }
                            <span class="rounded-circle @dotColor" style="width: 8px; height: 8px;"></span>
                            @statusName
                            <span class="text-muted-light fw-normal small ms-1">@statusTasks.Count</span>
                        </h3>
                        <a asp-controller="ProjectTask" asp-action="Create" asp-route-projectId="@Model.ProjectId" class="btn btn-link p-0 text-muted-light">
                            <span class="material-symbols-outlined fs-6">add</span>
                        </a>
                    </div>
                    
                    <div class="bg-surface-light rounded-3 shadow-soft border border-border-light overflow-hidden">
                        @foreach (var task in statusTasks)
                        {
                            <div class="task-row d-flex align-items-center justify-content-between p-3 border-bottom border-border-light" 
                                 onclick="window.location.href='@Url.Action("Detail", "ProjectTask", new { id = task.Id, projectId = Model.ProjectId })'"
                                 style="cursor: pointer;">
                                <div class="d-flex align-items-center gap-3 min-w-0">
                                    <div class="rounded border border-border-light bg-white shadow-sm d-flex align-items-center justify-content-center @(task.Status == MvcProject.Models.Enums.TaskStatus.Done ? "bg-success-light" : "")" style="width: 20px; height: 20px;">
                                        <span class="material-symbols-outlined @(task.Status == MvcProject.Models.Enums.TaskStatus.Done ? "text-success" : "text-transparent")" style="font-size: 14px;">check</span>
                                    </div>
                                    <div class="min-w-0 d-flex align-items-center gap-2">
                                        <p class="fw-medium small text-dark mb-0 text-truncate @(task.Status == MvcProject.Models.Enums.TaskStatus.Done ? "text-decoration-line-through text-muted" : "")">@task.Title</p>
                                        @if (task.Priority == MvcProject.Models.Enums.TaskPriority.High)
                                        {
                                            <span class="badge fw-medium d-none d-sm-inline-block" style="background-color: #FEE2E2; color: #991B1B; font-size: 10px;">High</span>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-3">
                                    @if (task.Deadline.HasValue)
                                    {
                                        <div class="d-none d-sm-flex align-items-center gap-1 small @(task.Deadline < DateTime.Now && task.Status != MvcProject.Models.Enums.TaskStatus.Done ? "text-danger fw-medium" : "text-muted-light")">
                                            <span class="material-symbols-outlined" style="font-size: 14px;">@(task.Deadline < DateTime.Now && task.Status != MvcProject.Models.Enums.TaskStatus.Done ? "error" : "calendar_today")</span>
                                            @task.Deadline.Value.ToString("MMM dd")
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(task.AssigneePhotoUrl))
                                    {
                                        <img src="@task.AssigneePhotoUrl" alt="@task.AssigneeName" class="rounded-circle border border-border-light" title="@task.AssigneeName" style="width: 24px; height: 24px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-light border border-border-light border-dashed d-flex align-items-center justify-content-center text-muted-light" title="@task.AssigneeName" style="width: 24px; height: 24px;">
                                            <span class="material-symbols-outlined" style="font-size: 12px;">person_add</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        @if (!Model.Tasks.Any())
        {
            <div class="text-center py-5 border border-dashed border-border-light rounded-3 bg-surface-light">
                <span class="material-symbols-outlined text-muted-light fs-1 mb-2">task_alt</span>
                <p class="text-muted-light mb-3">No tasks found for this project.</p>
                <a asp-controller="ProjectTask" asp-action="Create" asp-route-projectId="@Model.ProjectId" class="btn btn-outline-primary btn-sm">
                    Create First Task
                </a>
            </div>
        }
        
    </div>
</div>
