@model MvcProject.ViewModels.Projects.ProjectDetailsViewModel
@{
    ViewData["Title"] = "Project Details";
}

<div class="mx-auto pb-5" style="max-width: 1200px;">
    <!-- Project Header -->
    <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center gap-3 mb-2">
                <h1 class="fs-3 fs-sm-2 font-display fw-bold text-dark mb-0 tracking-tight">@Model.Title</h1>
                <span class="badge rounded-pill fw-semibold" style="background-color: #FEF3C7; color: #92400E;">@Model.CompletionPercentage%</span>
            </div>
            <p class="text-muted-light small mb-0" style="max-width: 42rem;">
                @Model.Description
            </p>
        </div>
        
        <div class="d-flex align-items-center gap-2 align-self-start">
            <div class="d-none d-sm-flex align-items-center me-2">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAx4DjjP-gqLBNa_JyURjDJdEaWBCnmTVrk76upE7cD3pRhNHMdSLWKkH60D5Erd0vToZddqm88_BIl1cYR4HbbdWA6f2HaOAGC70mXape7LJmx_yNiBVQkhjX8-uLQpAsmNgSoRFUKOm0hGjTd633nvrqpKDo6H-PZzuzMljkXIVOZwZunhclSz8z2KI21XHfSnejud2O9M0P_yCFszN0LFq_opAqj8LQuy2SAFCxFtyhIF7S7mmi9ZF0uOtC6TXLheEgodEBV7v2j" alt="Team member" class="rounded-circle border border-2 border-white object-fit-cover" style="width: 32px; height: 32px; z-index: 3;">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCU_4K8R15USDca_tYDCPrOylUfjUhpDzSxOdwqdhCw-GSEjFTof9E0ADecoAvM90ktMwrmZQLjTrORgHIWHHnZ6Lxi4nVy_Kzk8jwxVwI9WTy27byfKKhe5snFSHf9xBGAx-N_VDp8bmoDj41GI_eINdpnOQVowaQ26nn6XmaF3ccm25-W-V2EJ1CtVGQJigX1fdADGPrADwZnActTpLC9PZbxNN6DfN3qqL0YBhXkRj1qjVwbbrBShh4wLSrWl0-BZryJvwf-Jpmw" alt="Team member" class="rounded-circle border border-2 border-white object-fit-cover" style="width: 32px; height: 32px; margin-left: -8px; z-index: 2;">
                <div class="rounded-circle border border-2 border-white bg-light d-flex align-items-center justify-content-center text-muted fw-medium" style="width: 32px; height: 32px; margin-left: -8px; font-size: 12px; z-index: 1;">+3</div>
            </div>
            @if (Model.IsCurrentUserAdmin)
            {
                <a asp-controller="Projects" asp-action="Members" asp-route-projectId="@Model.ProjectId" class="btn btn-outline-primary fw-semibold font-display shadow-sm" style="font-size: 0.875rem;">
                    Members
                </a>
                <button type="button" class="btn btn-light bg-surface-light border-border-light text-dark fw-semibold font-display shadow-sm" style="font-size: 0.875rem;" data-bs-toggle="modal" data-bs-target="#editProjectModal">
                    Edit Project
                </button>
                <button type="button" class="btn btn-danger fw-semibold font-display shadow-sm" style="font-size: 0.875rem;" data-bs-toggle="modal" data-bs-target="#deleteProjectModal">
                    Delete Project
                </button>
            }
        </div>
    </div>

    <div class="bg-surface-light rounded-3 border border-border-light p-3 p-sm-4 shadow-soft mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="small text-muted-light">Task Completion</span>
            <span class="small fw-semibold text-dark">@Model.CompletedTasks / @Model.TotalTasks</span>
        </div>
        <div class="progress w-100 bg-border-light rounded-pill" style="height: 6px;">
            <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: @Model.CompletionPercentage%;" aria-valuenow="@Model.CompletionPercentage" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>

    <!-- Status Preview Summary -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="bg-surface-light border border-border-light rounded-4 p-3 shadow-soft d-flex align-items-center gap-3">
                <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <span class="material-symbols-outlined text-secondary fs-5">assignment_late</span>
                </div>
                <div>
                    <div class="extra-small fw-bold text-muted-light text-uppercase tracking-wider">To Do</div>
                    <div class="fs-5 fw-bold text-dark">@Model.ToDoTasks.Count</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="bg-surface-light border border-border-light rounded-4 p-3 shadow-soft d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <span class="material-symbols-outlined text-primary fs-5">pending_actions</span>
                </div>
                <div>
                    <div class="extra-small fw-bold text-muted-light text-uppercase tracking-wider">In Progress</div>
                    <div class="fs-5 fw-bold text-dark">@Model.InProgressTasks.Count</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="bg-surface-light border border-border-light rounded-4 p-3 shadow-soft d-flex align-items-center gap-3">
                <div class="rounded-circle bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: rgba(168, 85, 247, 0.1);">
                    <span class="material-symbols-outlined fs-5" style="color: #A855F7;">rate_review</span>
                </div>
                <div>
                    <div class="extra-small fw-bold text-muted-light text-uppercase tracking-wider">Review</div>
                    <div class="fs-5 fw-bold text-dark">@Model.ReviewTasks.Count</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="bg-surface-light border border-border-light rounded-4 p-3 shadow-soft d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <span class="material-symbols-outlined text-success fs-5">task_alt</span>
                </div>
                <div>
                    <div class="extra-small fw-bold text-muted-light text-uppercase tracking-wider">Completed</div>
                    <div class="fs-5 fw-bold text-dark">@Model.DoneTasks.Count</div>
                </div>
            </div>
        </div>
    </div>

<div class="modal fade" id="editProjectModal" tabindex="-1" aria-labelledby="editProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-soft rounded-4">
            <div class="modal-header border-bottom border-border-light">
                <h5 class="modal-title font-display fw-bold text-dark" id="editProjectModalLabel">Edit Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Projects" asp-action="EditProject" asp-route-projectId="@Model.ProjectId" method="post">
                <input type="hidden" asp-for="EditProject.Id" />

                <div class="modal-body d-flex flex-column gap-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div>
                        <label asp-for="EditProject.Title" class="form-label fw-semibold text-dark"></label>
                        <input asp-for="EditProject.Title" class="form-control" />
                        <span asp-validation-for="EditProject.Title" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="EditProject.Description" class="form-label fw-semibold text-dark"></label>
                        <textarea asp-for="EditProject.Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="EditProject.Description" class="text-danger small"></span>
                    </div>
                </div>

                <div class="modal-footer border-top border-border-light">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteProjectModal" tabindex="-1" aria-labelledby="deleteProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-soft rounded-4">
            <div class="modal-header border-bottom border-border-light">
                <h5 class="modal-title font-display fw-bold text-dark" id="deleteProjectModalLabel">Delete Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-0 text-muted-light">Are you sure you want to delete this project? This action cannot be undone.</p>
            </div>

            <div class="modal-footer border-top border-border-light">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <form asp-controller="Projects" asp-action="DeleteProject" asp-route-projectId="@Model.ProjectId" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

    <!-- Tab Navigation -->
    <div class="border-bottom border-border-light mb-4">
        <ul class="nav nav-tabs border-bottom-0 flex-nowrap overflow-auto pb-0" style="gap: 2rem;">
            <li class="nav-item">
                <a class="nav-link active rounded-0 border-top-0 border-start-0 border-end-0 border-bottom border-2 border-primary fw-semibold font-display px-1 py-3" href="#" style="color: black !important;">Tasks</a>
            </li>
        </ul>
    </div>

    <div class="d-flex flex-column gap-4">
        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle bg-secondary" style="width: 8px; height: 8px;"></span>
                    To Do
                    <span class="text-muted-light fw-normal small ms-1">@Model.ToDoTasks.Count</span>
                </h3>
                @if (Model.IsCanCreateTask)
                {
                    <a asp-controller="ProjectTask" asp-action="Create" asp-route-projectId="@Model.ProjectId" class="btn btn-sm btn-primary ms-2 shadow-sm fw-semibold" style="font-size:0.875rem;">
                        Create Task
                    </a>
                }
            </div>

            <div class="bg-surface-light rounded-3 shadow-soft border border-border-light overflow-hidden">
                @if (Model.ToDoTasks.Any())
                {
                    @for (var i = 0; i < Model.ToDoTasks.Count; i++)
                    {
                        var task = Model.ToDoTasks[i];
                        <a asp-controller="ProjectTask" asp-action="Detail" asp-route-id="@task.Id" asp-route-projectId="@Model.ProjectId" class="task-row d-flex align-items-center justify-content-between p-3 @(i < Model.ToDoTasks.Count - 1 ? "border-bottom border-border-light" : string.Empty) text-decoration-none" style="cursor: pointer;">
                            <div class="d-flex align-items-center gap-3 min-w-0">
                                <div class="bg-light rounded p-2 d-flex align-items-center justify-content-center me-3 shadow-xs">
                                    <span class="material-symbols-outlined text-muted-light fs-5">assignment</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="fw-medium small text-dark mb-0 text-truncate transition-colors">@task.Title</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-3">
                                <div class="d-none d-sm-flex align-items-center gap-1 small text-muted-light">
                                    <span class="material-symbols-outlined" style="font-size: 14px;">calendar_today</span>
                                    @(task.Deadline?.ToString("MMM dd") ?? "No deadline")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(task.AssigneeAvatarUrl))
                                {
                                    <img src="@task.AssigneeAvatarUrl" alt="Assignee" class="rounded-circle border border-border-light" style="width: 24px; height: 24px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-light border border-border-light border-dashed d-flex align-items-center justify-content-center text-muted-light" style="width: 24px; height: 24px;">
                                        <span class="material-symbols-outlined" style="font-size: 12px;">person</span>
                                    </div>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="p-3 small text-muted-light">No tasks in this category.</div>
                }
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle bg-primary" style="width: 8px; height: 8px;"></span>
                    In Progress
                    <span class="text-muted-light fw-normal small ms-1">@Model.InProgressTasks.Count</span>
                </h3>
            </div>

            <div class="bg-surface-light rounded-3 shadow-soft border border-border-light overflow-hidden">
                @if (Model.InProgressTasks.Any())
                {
                    @for (var i = 0; i < Model.InProgressTasks.Count; i++)
                    {
                        var task = Model.InProgressTasks[i];
                        <a asp-controller="ProjectTask" asp-action="Detail" asp-route-id="@task.Id" asp-route-projectId="@Model.ProjectId" class="task-row d-flex align-items-center justify-content-between p-3 @(i < Model.InProgressTasks.Count - 1 ? "border-bottom border-border-light" : string.Empty) text-decoration-none" style="cursor: pointer;">
                            <div class="d-flex align-items-center gap-3 min-w-0">
                                <div class="bg-light rounded p-2 d-flex align-items-center justify-content-center me-3 shadow-xs">
                                    <span class="material-symbols-outlined text-muted-light fs-5">assignment</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="fw-medium small text-dark mb-0 text-truncate transition-colors">@task.Title</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-3">
                                <div class="d-none d-sm-flex align-items-center gap-1 small text-muted-light">
                                    <span class="material-symbols-outlined" style="font-size: 14px;">calendar_today</span>
                                    @(task.Deadline?.ToString("MMM dd") ?? "No deadline")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(task.AssigneeAvatarUrl))
                                {
                                    <img src="@task.AssigneeAvatarUrl" alt="Assignee" class="rounded-circle border border-border-light" style="width: 24px; height: 24px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-light border border-border-light border-dashed d-flex align-items-center justify-content-center text-muted-light" style="width: 24px; height: 24px;">
                                        <span class="material-symbols-outlined" style="font-size: 12px;">person</span>
                                    </div>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="p-3 small text-muted-light">No tasks in this category.</div>
                }
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle" style="width: 8px; height: 8px; background-color: #A855F7;"></span>
                    Review
                    <span class="text-muted-light fw-normal small ms-1">@Model.ReviewTasks.Count</span>
                </h3>
            </div>

            <div class="bg-surface-light rounded-3 shadow-soft border border-border-light overflow-hidden">
                @if (Model.ReviewTasks.Any())
                {
                    @for (var i = 0; i < Model.ReviewTasks.Count; i++)
                    {
                        var task = Model.ReviewTasks[i];
                        <a asp-controller="ProjectTask" asp-action="Detail" asp-route-id="@task.Id" asp-route-projectId="@Model.ProjectId" class="task-row d-flex align-items-center justify-content-between p-3 @(i < Model.ReviewTasks.Count - 1 ? "border-bottom border-border-light" : string.Empty) text-decoration-none" style="cursor: pointer;">
                            <div class="d-flex align-items-center gap-3 min-w-0">
                                <div class="bg-light rounded p-2 d-flex align-items-center justify-content-center me-3 shadow-xs">
                                    <span class="material-symbols-outlined text-muted-light fs-5">assignment</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="fw-medium small text-dark mb-0 text-truncate transition-colors">@task.Title</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-3">
                                <div class="d-none d-sm-flex align-items-center gap-1 small text-muted-light">
                                    <span class="material-symbols-outlined" style="font-size: 14px;">calendar_today</span>
                                    @(task.Deadline?.ToString("MMM dd") ?? "No deadline")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(task.AssigneeAvatarUrl))
                                {
                                    <img src="@task.AssigneeAvatarUrl" alt="Assignee" class="rounded-circle border border-border-light" style="width: 24px; height: 24px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-light border border-border-light border-dashed d-flex align-items-center justify-content-center text-muted-light" style="width: 24px; height: 24px;">
                                        <span class="material-symbols-outlined" style="font-size: 12px;">person</span>
                                    </div>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="p-3 small text-muted-light">No tasks in this category.</div>
                }
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between">
                <h3 class="font-display fw-semibold text-dark fs-6 mb-0 d-flex align-items-center gap-2">
                    <span class="rounded-circle" style="width: 8px; height: 8px; background-color: #10B981;"></span>
                    Done
                    <span class="text-muted-light fw-normal small ms-1">@Model.DoneTasks.Count</span>
                </h3>
            </div>

            <div class="bg-surface-light rounded-3 shadow-soft border border-border-light overflow-hidden">
                @if (Model.DoneTasks.Any())
                {
                    @for (var i = 0; i < Model.DoneTasks.Count; i++)
                    {
                        var task = Model.DoneTasks[i];
                        <a asp-controller="ProjectTask" asp-action="Detail" asp-route-id="@task.Id" asp-route-projectId="@Model.ProjectId" class="task-row d-flex align-items-center justify-content-between p-3 @(i < Model.DoneTasks.Count - 1 ? "border-bottom border-border-light" : string.Empty) text-decoration-none" style="cursor: pointer;">
                            <div class="d-flex align-items-center gap-3 min-w-0">
                                <div class="bg-success-subtle rounded p-2 d-flex align-items-center justify-content-center me-3 shadow-xs">
                                    <span class="material-symbols-outlined text-success fs-5">task_alt</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="fw-medium small text-dark mb-0 text-truncate transition-colors text-decoration-line-through">@task.Title</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3 flex-shrink-0 ms-3">
                                <div class="d-none d-sm-flex align-items-center gap-1 small text-muted-light">
                                    <span class="material-symbols-outlined" style="font-size: 14px;">calendar_today</span>
                                    @(task.Deadline?.ToString("MMM dd") ?? "No deadline")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(task.AssigneeAvatarUrl))
                                {
                                    <img src="@task.AssigneeAvatarUrl" alt="Assignee" class="rounded-circle border border-border-light" style="width: 24px; height: 24px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-light border border-border-light border-dashed d-flex align-items-center justify-content-center text-muted-light" style="width: 24px; height: 24px;">
                                        <span class="material-symbols-outlined" style="font-size: 12px;">person</span>
                                    </div>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="p-3 small text-muted-light">No tasks in this category.</div>
                }
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        $(document).ready(function() {

            // Task management is now handled through Task Detail/Edit views
        });
    </script>
}
