@{
    ViewData["Title"] = "Team Management";
}

<div class="mx-auto pb-5 d-flex flex-column gap-4" style="max-width: 1200px;">
    <!-- Title and Filters -->
    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
        <div>
            <h2 class="font-display fw-bold fs-4 text-dark mb-1">Team Management</h2>
            <p class="text-muted-light small mb-0">Manage your team members, workspace permissions, and invites.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="d-flex bg-surface-light p-1 rounded-3 border border-border-light shadow-soft">
                <button class="btn btn-sm btn-light bg-light rounded text-primary fw-bold border-0 shadow-none px-3" style="font-size: 0.75rem;">All Members</button>
                <button class="btn btn-sm btn-link text-muted-light fw-semibold text-decoration-none shadow-none px-3 hover-text-dark" style="font-size: 0.75rem;">Design</button>
                <button class="btn btn-sm btn-link text-muted-light fw-semibold text-decoration-none shadow-none px-3 hover-text-dark" style="font-size: 0.75rem;">Engineering</button>
            </div>
        </div>
    </div>

