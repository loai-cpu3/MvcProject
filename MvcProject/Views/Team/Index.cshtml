            <div class="bg-surface-light p-4 rounded-4 border border-border-light shadow-soft position-relative text-center hover-shadow transition-all w-100">
                <button class="btn btn-link position-absolute top-0 end-0 p-3 text-muted-light hover-text-dark shadow-none text-decoration-none">
