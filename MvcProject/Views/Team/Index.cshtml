@model MvcProject.Controllers.TeamIndexViewModel

@{
    ViewData["Title"] = "Team";
}

<div class="mx-auto pb-5 d-flex flex-column gap-4" style="max-width: 1200px;">
    <!-- Title -->
    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
        <div>
            <h2 class="font-display fw-bold fs-4 text-dark mb-1">Team</h2>
            <p class="text-muted-light small mb-0">People you work with across all your projects.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill fw-bold px-3 py-2" style="font-size: 0.8rem;">
                <span class="material-symbols-outlined align-middle me-1" style="font-size: 16px;">group</span>
                @Model.Members.Count member@(Model.Members.Count != 1 ? "s" : "")
            </span>
        </div>
    </div>

    @if (Model.Members.Count == 0)
    {
        <div class="bg-surface-light rounded-4 border border-border-light shadow-soft p-5 text-center">
            <span class="material-symbols-outlined d-block mb-3 text-muted-light" style="font-size: 64px; opacity: 0.3;">group_off</span>
            <h4 class="font-display fw-bold text-dark mb-2">No team members yet</h4>
            <p class="text-muted-light small mb-3">Join or create a project to start collaborating with others.</p>
            <a asp-controller="Projects" asp-action="Index" class="btn rounded-pill text-white fw-medium px-4 py-2" style="background-color: #6366f1;">
                Go to Projects
            </a>
        </div>
    }
    else
    {
        <!-- Member Grid -->
        <div class="row g-4">
            @foreach (var member in Model.Members)
            {
                var isCurrentUser = member.UserId == Model.CurrentUserId;
                var roleBadgeClass = member.Role switch
                {
                    ProjectRole.Admin => "bg-danger bg-opacity-10 text-danger",
                    ProjectRole.Manager => "bg-warning bg-opacity-10 text-warning",
                    _ => "bg-primary bg-opacity-10 text-primary"
                };
                var roleIcon = member.Role switch
                {
                    ProjectRole.Admin => "shield_person",
                    ProjectRole.Manager => "manage_accounts",
                    _ => "person"
                };

                <div class="col-12 col-md-6 col-lg-3">
                    <div class="bg-surface-light p-4 rounded-4 border border-border-light shadow-soft position-relative text-center hover-shadow transition-all w-100 h-100 d-flex flex-column">
                        @if (isCurrentUser)
                        {
                            <span class="position-absolute top-0 start-0 m-3 badge bg-primary bg-opacity-10 text-primary rounded-pill fw-bold" style="font-size: 9px;">You</span>
                        }

                        <div class="position-relative mx-auto mt-2 mb-3" style="width: 80px; height: 80px;">
                            @if (!string.IsNullOrEmpty(member.AvatarUrl))
                            {
                                <img src="@member.AvatarUrl" alt="@member.FullName"
                                     class="w-100 h-100 rounded-circle border border-4 border-light shadow-inner object-fit-cover">
                            }
                            else
                            {
                                var initials = member.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                var initialsText = initials.Length >= 2
                                    ? $"{initials[0][0]}{initials[^1][0]}".ToUpper()
                                    : (initials.Length == 1 ? initials[0][0].ToString().ToUpper() : "?");
                                <div class="w-100 h-100 rounded-circle border border-4 border-light shadow-inner d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="background: linear-gradient(135deg, #6366f1, #8b5cf6); font-size: 1.5rem;">
                                    @initialsText
                                </div>
                            }
                        </div>

                        <h3 class="font-display fw-bold text-dark fs-6 mb-1">@member.FullName</h3>
                        <p class="text-muted-light mb-3" style="font-size: 0.75rem;">@member.Email</p>

                        <div class="mt-auto d-flex flex-column gap-2">
                            <div class="d-flex align-items-center justify-content-center gap-1">
                                <span class="material-symbols-outlined" style="font-size: 14px;">@roleIcon</span>
                                <span class="badge @roleBadgeClass rounded-pill fw-bold" style="font-size: 10px;">@member.Role</span>
                            </div>
                            <div class="d-flex flex-wrap justify-content-center gap-1" style="max-height: 48px; overflow: hidden;">
                                @foreach (var projectName in member.ProjectNames.Take(3))
                                {
                                    <span class="badge bg-light text-muted-light rounded fw-medium" style="font-size: 9px;">@projectName</span>
                                }
                                @if (member.ProjectNames.Count > 3)
                                {
                                    <span class="badge bg-light text-muted-light rounded fw-medium" style="font-size: 9px;">+@(member.ProjectNames.Count - 3) more</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
