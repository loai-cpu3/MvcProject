                    <span class="position-absolute bottom-0 end-0 rounded-circle border border-2 border-white bg-secondary" style="width: 16px; height: 16px; margin-bottom: 4px; margin-right: 4px;" title="Offline"></span>
                </div>
                <h3 class="font-display fw-bold text-dark fs-6 mb-1">Marcus Vane</h3>
                <p class="text-primary fw-semibold mb-0" style="font-size: 0.75rem;">Growth Lead</p>
                <div class="mt-4 d-flex align-items-center justify-content-between text-uppercase tracking-wider fw-bold" style="font-size: 10px;">
