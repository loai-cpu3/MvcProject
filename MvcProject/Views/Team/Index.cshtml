                    <span class="position-absolute bottom-0 end-0 rounded-circle border border-2 border-white" style="width: 16px; height: 16px; background-color: var(--velocity-accent); margin-bottom: 4px; margin-right: 4px;" title="Active"></span>
                </div>
                <h3 class="font-display fw-bold text-dark fs-6 mb-1">Elena Rodriguez</h3>
                <p class="text-primary fw-semibold mb-0" style="font-size: 0.75rem;">QA Automation</p>
                <div class="mt-4 d-flex align-items-center justify-content-between text-uppercase tracking-wider fw-bold" style="font-size: 10px;">
                    <span class="bg-light text-muted-light px-2 py-1 rounded">Engineering</span>
                    <span class="d-flex align-items-center gap-1" style="color: var(--velocity-accent);">Active</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Invitations -->
    <div class="d-flex flex-column gap-3 mt-2">
        <div class="d-flex align-items-center gap-2">
            <span class="material-symbols-outlined text-primary fs-5">schedule_send</span>
            <h3 class="font-display fw-bold text-dark fs-5 mb-0">Pending Invitations</h3>
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill fw-bold" style="font-size: 10px;">2</span>
        </div>

        <div class="bg-surface-light rounded-4 border border-border-light overflow-hidden shadow-soft">
            <div class="table-responsive">
                <table class="table table-borderless table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th scope="col" class="px-4 py-3 text-muted-light fw-bold text-uppercase tracking-wider" style="font-size: 10px;">Email Address</th>
                            <th scope="col" class="px-4 py-3 text-muted-light fw-bold text-uppercase tracking-wider" style="font-size: 10px;">Role</th>
                            <th scope="col" class="px-4 py-3 text-muted-light fw-bold text-uppercase tracking-wider" style="font-size: 10px;">Sent Date</th>
                            <th scope="col" class="px-4 py-3 text-end text-muted-light fw-bold text-uppercase tracking-wider" style="font-size: 10px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <tr class="border-bottom border-border-light">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        <span class="material-symbols-outlined text-muted-light" style="font-size: 16px;">mail</span>
                                    </div>
                                    <span class="small fw-medium">leo.k@company.com</span>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded fw-bold" style="font-size: 10px;">Editor</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="small text-muted-light fw-medium">Oct 12, 2023</span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <button class="btn btn-link p-0 text-primary fw-bold text-decoration-none hover-underline small me-3">Resend</button>
                                <button class="btn btn-link p-0 text-danger fw-bold text-decoration-none hover-underline small">Revoke</button>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        <span class="material-symbols-outlined text-muted-light" style="font-size: 16px;">mail</span>
                                    </div>
                                    <span class="small fw-medium">amanda.w@agency.net</span>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded fw-bold" style="font-size: 10px;">Viewer</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="small text-muted-light fw-medium">Oct 14, 2023</span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <button class="btn btn-link p-0 text-primary fw-bold text-decoration-none hover-underline small me-3">Resend</button>
                                <button class="btn btn-link p-0 text-danger fw-bold text-decoration-none hover-underline small">Revoke</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
