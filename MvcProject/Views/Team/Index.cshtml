                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCMgMaTH0VO4C6HfIGsy5FLZKasoNS4z4odAf3ZKhoLnes0BwvEP7Byna_8a9EDkwZ8mXyHrY14aLDo09u_apMBAK1enukzDcaKDcb1fwRDe35GWLkXeJkkBhUb3SOw4YM5d7lAuFZJff1lJlJyCj36HSvr9I6vNYq_pW-iwUgg3rwwW_JS3ioeze4W3UKhPjR9K-60gnBuvUkXekRNKeqiXlCNhWqVPoKf3JJM_-bZLO5vL-x-SwmRgxuHN_7dboS5NmKkKb4OH1jE" alt="Jordan Smith" class="w-100 h-100 rounded-circle border border-4 border-light shadow-inner object-fit-cover">
