                    <h3 class="font-display fw-bold fs-5 text-dark mb-0">My Tasks</h3>
                    <button class="btn btn-link text-primary fw-bold text-decoration-none shadow-none small">View All</button>
                </div>
                <div class="p-3 d-flex flex-column gap-2 overflow-auto">
                    
                    <!-- Task Row 1 -->
                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3 border-start border-4 border-danger shadow-sm bg-surface-light" style="cursor: pointer;">
                        <div class="d-flex align-items-center gap-3 overflow-hidden w-100">
                            <div class="rounded-circle border d-flex align-items-center justify-content-center text-white flex-shrink-0" style="width: 24px; height: 24px;">
                                <span class="material-symbols-outlined" style="font-size: 16px;">check</span>
                            </div>
                            <div class="d-flex flex-column min-w-0 flex-grow-1">
                                <p class="fw-bold text-dark mb-0 text-truncate" style="font-size: 0.95rem;">Finalize Q3 Marketing Campaign Assets</p>
                                <p class="small text-muted-light mb-0 text-truncate">Marketing Launch &bull; In Progress</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 ps-3 flex-shrink-0">
                            <span class="badge bg-danger bg-opacity-10 text-danger text-uppercase tracking-wider fw-bold">Today</span>
