@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mx-auto d-flex flex-column gap-4 pb-5" style="max-width: 1280px;">
    <!-- Header -->
    <div>
        @inject UserManager<MvcProject.Models.Domain.ApplicationUser> UserManager
        @{
            var currentUser = await UserManager.GetUserAsync(User);
        }
        <h2 class="font-display fw-bold text-dark tracking-tight mb-2" style="font-size: 2rem;">Good morning, @currentUser?.FirstName @currentUser?.LastName</h2>
        <p class="text-muted-light fw-medium mb-0">Here's what's happening with your projects today.</p>
    </div>

    <!-- Stats Row -->
    <div class="row g-4">
        <!-- Stat Card 1 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wide" style="letter-spacing: 0.05em;">Active Projects</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">folder</span>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <span class="font-display fw-bold text-primary mb-0" style="font-size: 2.75rem; line-height: 1;">12</span>
                    <span class="badge bg-success bg-opacity-10 text-success d-flex align-items-center gap-1 rounded-2">
                        <span class="material-symbols-outlined" style="font-size: 14px;">arrow_upward</span> 2
                    </span>
                </div>
            </div>
        </div>
        
        <!-- Stat Card 2 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wide" style="letter-spacing: 0.05em;">Pending Tasks</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">assignment</span>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <span class="font-display fw-bold text-dark mb-0" style="font-size: 2.75rem; line-height: 1;">48</span>
                    <span class="small fw-bold text-muted-light">14 due today</span>
                </div>
            </div>
        </div>
        
        <!-- Stat Card 3 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wide" style="letter-spacing: 0.05em;">Team Online</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">group</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <span class="font-display fw-bold text-dark mb-0" style="font-size: 2.75rem; line-height: 1;">8</span>
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle border border-2 border-white ms-n2" style="width: 32px; height: 32px; margin-left: 0; background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDLoBimi3eGNFNJxn77oK5yaWPUHjwCC7D8LgVRY4v3WxrkW1FsDBmiqD7DMaBRqHih3zVmC2TdWPf8WmokCd5pski9yI_Mf4Mu3S33KA4yqF2bvNHQrSBpRPQQQzR9dR8FP4bZx9SSiU_NXSYnIJxlK4MkpnEEgEQUffMwkHxFEAp8xAn-r0_8e46IY2uKAQJlHy5Slw8l2H0Db5yUJY5UpAa0F_yl7_1RATwK4zTo8t3QnyBqEV_zRHyOZcLfQfRB2u_B_ofIBZY0'); background-size: cover; background-position: center;"></div>
                        <div class="rounded-circle border border-2 border-white" style="width: 32px; height: 32px; margin-left: -10px; background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuChqweYvq4vDfTxexQlv5oesVy27JirNf3uHXiUspw-_WV8RmdiFogAzYq5FgIabCQeO5v6rb-xyIUgGbJQnEAP3oIMrvBA3kyoSu1JV0oX00_lW8-SexY2WlSixF2uZb0b7g4WHmiAMBVeA29DguTEcYZL8x9u1FACzleHsb2Qvezru-3VeAP4pPcd6PX85J2gPvh1Fb_GUF_gRiSmFHkf700naOi4g8vxbhssdEk_vk7IRax3-Gdh49GKKH89M0xvUpMuWZBsLXDb'); background-size: cover; background-position: center;"></div>
                        <div class="rounded-circle border border-2 border-white" style="width: 32px; height: 32px; margin-left: -10px; background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA1ezAkC_FBrZAw5K3bI3X6PChcbRWaKj3tHbkZhJ3npHkCqN8icHFtTb5AUzBEEdX4i6_WVrsD2YCGIYyYQolzBAXJ4yI-3Q0JfSuETzZmbA1NNLoIdcz_vf0_Uhf0fGB9f6jbD87J-UzhUaxHsAJl3DQxsijeTUyH8VVhj_YOI0883ujPYrGuq8t-uPcc8RSbJxGWZQd_gpZuWhRjxCdR1se00bjMsoGyO44pUnf21rtOgnKv977OWrWSuQ0_zmqmF4y_yT4tJ3jX'); background-size: cover; background-position: center;"></div>
                        <div class="bg-light rounded-circle border border-2 border-white d-flex align-items-center justify-content-center text-muted-light fw-bold" style="width: 32px; height: 32px; margin-left: -10px; font-size: 10px; z-index: 10;">+5</div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Stat Card 4 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wide" style="letter-spacing: 0.05em;">Completion Rate</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">trending_up</span>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <span class="font-display fw-bold text-dark mb-0" style="font-size: 2.75rem; line-height: 1;">85%</span>
                    <span class="small fw-bold text-muted-light">This week</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Grid: Tasks & Activity -->
    <div class="row g-4 mt-1">
        <!-- My Tasks List -->
        <div class="col-12 col-lg-8">
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light d-flex flex-column" style="min-height: 500px;">
