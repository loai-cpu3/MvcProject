                            <div class="d-flex flex-column">
                                <p class="small text-dark mb-1" style="line-height: 1.5;">
                                    <span class="fw-bold">Sarah Jenkins</span> completed task 
                                    <span class="fw-semibold text-primary">Update User Flow Diagrams</span>
                                </p>
                                <span class="text-uppercase fw-bold text-muted-light" style="font-size: 11px;">2 hours ago</span>
                            </div>
                        </div>

                        <!-- Activity Item 2 -->
                        <div class="d-flex gap-3">
                            <div class="rounded-circle border border-3 border-white shadow-sm flex-shrink-0" style="width: 40px; height: 40px; background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCIMuouwa44LWuuM89G-5WGtQSLaX47d029QcwPqB2z1spJ94ngtkxmuP38wDuJSDjmiEcg66VCyeTKK989EadEvxk2HCLog3-J41D2u9W72d--f05caE5w_WilC45wfUS7KQm68GC5faUz1-0kdRnlHxe2WusrbjGSwrMuyotAjv1KecTnr8mBEW53m30CzptAcHkRTdPPjA2sXroynWG9fnJaYkqmlRcIKlOtZmKnOwr81zsF8Ld7RfW6Qd6tKJbiys_mwbRXWtpR'); background-size: cover; background-position: center; position: relative; z-index: 2;"></div>
                            <div class="d-flex flex-column">
                                <p class="small text-dark mb-1" style="line-height: 1.5;">
                                    <span class="fw-bold">Michael Chen</span> added a comment to 
                                    <span class="fw-semibold text-primary">API Documentation</span>
                                </p>
                                <div class="mt-2 p-3 bg-light rounded-3 small text-secondary fst-italic border-start border-3 border-primary">
                                    "I've updated the endpoint structures, please review when you have a moment."
                                </div>
                                <span class="text-uppercase fw-bold text-muted-light mt-2" style="font-size: 11px;">4 hours ago</span>
                            </div>
                        </div>

                        <!-- Activity Item 3 -->
                        <div class="d-flex gap-3">
                            <div class="rounded-circle bg-primary bg-opacity-10 text-primary border border-3 border-white shadow-sm d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px; position: relative; z-index: 2;">
                                <span class="material-symbols-outlined fs-6 fw-bold">rocket_launch</span>
                            </div>
                            <div class="d-flex flex-column">
                                <p class="small text-dark mb-1" style="line-height: 1.5;">
