@using Microsoft.AspNetCore.Identity
@using MvcProject.ViewModels.Home
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var dashboard = Model ?? new DashboardViewModel();
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
}

<div class="mx-auto d-flex flex-column gap-4 pb-5" style="max-width: 1280px;">
    <!-- Header -->
    <div>
        @inject UserManager<MvcProject.Models.Domain.ApplicationUser> UserManager
        @{
            var currentUser = await UserManager.GetUserAsync(User);
        }
        @{
            var hour = DateTime.Now.Hour;
            var greeting = hour switch
            {
                >= 5 and < 12 => "Good morning",
                >= 12 and < 17 => "Good afternoon",
                _ => "Good evening"
            };
        }
        <h2 class="font-display fw-bold text-dark tracking-tight mb-2" style="font-size: 2rem;">@greeting, @currentUser?.FirstName @currentUser?.LastName</h2>
        <p class="text-muted-light fw-medium mb-0">Here's what's happening with your projects today.</p>
    </div>

    <!-- Stats Row -->
    <div class="row g-4">
        <!-- Stat Card 1 -->
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wider">Active Projects</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">folder</span>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <span class="font-display fw-bold text-dark mb-0" style="font-size: 2.75rem; line-height: 1;">@dashboard.TotalProjects</span>
                </div>
            </div>
        </div>

        <!-- Stat Card 2 -->
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wider">Pending Tasks</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">assignment</span>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <span class="font-display fw-bold text-dark mb-0" style="font-size: 2.75rem; line-height: 1;">@dashboard.TotalPendingTasks</span>
                    <span class="small fw-bold text-muted-light">Open items</span>
                </div>
            </div>
        </div>

        <!-- Stat Card 3 - Completion Rate -->
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="bg-surface-light rounded-4 p-4 shadow-soft border border-border-light d-flex flex-column justify-content-between h-100" style="min-height: 150px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="small fw-bold text-muted-light text-uppercase tracking-wider">Completion Rate</span>
                    <span class="material-symbols-outlined text-primary opacity-75 fs-4">trending_up</span>
                </div>
                <div class="d-flex align-items-baseline gap-2">
                    <span class="font-display fw-bold text-dark mb-0" style="font-size: 2.75rem; line-height: 1;">@dashboard.CompletionRate.ToString("0.#")%</span>
                    <span class="small fw-bold text-muted-light">This week</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tasks and Activity Row -->
    <div class="row g-4">
        <!-- My Tasks (Left Column) -->
        <div class="col-12 col-xl-7 col-xxl-8">
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light d-flex flex-column h-100">
                <div class="px-4 py-3 border-bottom border-border-light d-flex align-items-center justify-content-between">
                    <h3 class="font-display fw-bold fs-5 text-dark mb-0">My Tasks</h3>
                    <a asp-controller="ProjectTask" asp-action="MyTasks" class="btn btn-link text-primary fw-bold text-decoration-none shadow-none small">View All</a>
                </div>
                <div class="p-3 d-flex flex-column gap-2 overflow-auto" style="min-height: 200px; max-height: 500px;">
                    @if (dashboard.RecentTasks.Any())
                    {
                        @foreach (var task in dashboard.RecentTasks)
                        {
                            var daysUntilDue = task.DueDate.DayNumber - today.DayNumber;
                            var dueText = task.DueDate == today
                                ? "Today"
                                : task.DueDate == today.AddDays(1)
                                    ? "Tomorrow"
                                    : task.DueDate.ToString("MMM dd");

                            var borderClass = daysUntilDue switch
                            {
                                >= 10 => "border-primary",
                                >= 4 and <= 9 => "border-warning",
                                >= 0 and <= 3 => "border-danger",
                                _ => "border-secondary"
                            };

                            <a asp-controller="ProjectTask" asp-action="Detail" asp-route-id="@task.Id" asp-route-projectId="@task.ProjectId"
                               class="d-flex align-items-center justify-content-between p-3 rounded-3 border-start border-4 @borderClass shadow-sm bg-surface-light text-decoration-none task-row" style="cursor: pointer;">
                                <div class="d-flex align-items-center gap-3 overflow-hidden w-100">
                                    <div class="rounded-circle border d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; height: 24px; border-color: var(--bs-primary);">
                                        <span class="material-symbols-outlined text-primary" style="font-size: 16px;">check</span>
                                    </div>
                                    <div class="d-flex flex-column min-w-0 flex-grow-1">
                                        <p class="fw-bold text-dark mb-0 text-truncate" style="font-size: 0.95rem;">@task.Title</p>
                                        <p class="small text-muted-light mb-0 text-truncate">@task.ProjectName &bull; @task.Status</p>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3 ps-3 flex-shrink-0">
                                    <span class="small fw-bold text-muted-light text-uppercase tracking-wider">@dueText</span>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px;">
                                <span class="material-symbols-outlined text-muted-light" style="font-size: 28px;">task_alt</span>
                            </div>
                            <p class="text-muted-light small mb-2">No tasks assigned to you yet.</p>
                            <a asp-controller="Projects" asp-action="Index" class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm">Go to Projects</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Activity Feed (Right Column) -->
        <div class="col-12 col-xl-5 col-xxl-4">
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light d-flex flex-column h-100">
                <div class="px-4 py-3 border-bottom border-border-light">
                    <h3 class="font-display fw-bold fs-5 text-dark mb-0">Recent Activity</h3>
                </div>
                <div class="p-4 d-flex flex-column gap-4 overflow-auto" style="min-height: 200px; max-height: 500px;">
                    @if (dashboard.RecentActivities.Any())
                    {
                        <div class="position-relative ms-2">
                            <!-- Timeline continuous line -->
                            <div class="position-absolute border-start border-border-light" style="top: 16px; bottom: 0; left: 16px; z-index: 0;"></div>
                            
                            @foreach (var activity in dashboard.RecentActivities)
                            {
                                var icon = activity.ActionType switch {
                                    "Create" => "add_task",
                                    "Update" => "edit",
                                    "StatusChange" => "swap_horiz",
                                    "Assignment" => "person_add",
                                    "Delete" => "delete",
                                    _ => "notifications"
                                };
                                var colorClass = activity.ActionType switch {
                                    "Create" => "bg-success text-white",
                                    "Update" => "bg-primary text-white",
                                    "StatusChange" => "bg-warning text-dark",
                                    "Assignment" => "bg-info text-white",
                                    "Delete" => "bg-danger text-white",
                                    _ => "bg-secondary text-white"
                                };

                                <div class="d-flex align-items-start gap-3 mb-4 position-relative" style="z-index: 1;">
                                    <!-- Activity Icon Badge -->
                                    <div class="rounded-circle @colorClass d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm" style="width: 32px; height: 32px; border: 4px solid var(--velocity-surface-light);">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">@icon</span>
                                    </div>
                                    
                                    <!-- Activity Content -->
                                    <div class="d-flex flex-column mt-1">
                                        <p class="mb-1 text-dark" style="font-size: 0.9rem; line-height: 1.4;">
                                            <span class="fw-bold">@activity.UserName</span> @activity.Description
                                            <a asp-controller="ProjectTask" asp-action="Detail" asp-route-id="@activity.TaskId" asp-route-projectId="@activity.ProjectId" class="fw-bold text-primary text-decoration-none">@activity.TaskTitle</a>
                                        </p>
                                        
                                        @if (activity.ActionType == "StatusChange" && !string.IsNullOrEmpty(activity.OldValue) && !string.IsNullOrEmpty(activity.NewValue))
                                        {
                                            <div class="d-flex align-items-center gap-2 mb-2 mt-1" style="font-size: 0.75rem;">
                                                <span class="badge bg-light text-muted-light border px-2 py-1">@activity.OldValue</span>
                                                <span class="material-symbols-outlined text-muted-light" style="font-size: 12px;">arrow_forward</span>
                                                <span class="badge bg-white text-dark border border-primary border-opacity-25 shadow-sm px-2 py-1">@activity.NewValue</span>
                                            </div>
                                        }
                                        
                                        <span class="text-muted-light fw-medium mt-1" style="font-size: 0.75rem;">@activity.CreatedAt.ToLocalTime().ToString("MMM dd, h:mm tt") &bull; @activity.ProjectTitle</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <span class="material-symbols-outlined text-muted-light opacity-50 mb-3" style="font-size: 48px;">history</span>
                            <p class="text-muted-light small mb-0 fw-medium">No recent activity found.</p>
                            <p class="text-muted-light small opacity-75">Events will appear here soon.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
