                            <span class="badge bg-warning bg-opacity-10 text-warning text-uppercase tracking-wider fw-bold">Tomorrow</span>
                            <div class="rounded-circle border border-white shadow-sm" style="width: 32px; height: 32px; background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDNKokdS5z5IDVgNAs8HtuRM2mGcoU6kXWH3ufMOXRwPBup8HvM8Hg0AwCW-jPUl0rikvOYR7I3f8Vg3QQ1BjTjMXEbjM3q-VhK1V79RpjsCFRs0bZC5nPbbpYxmf0taaLj6Wtbk05t4hNuaD_SyklDrQMhJaU1KYdWHU15Cdapf_253oqgk-G6MVqIgqa7MEnS29gjOwE2sIYwIeNtfQtsHoVOg5foDlSiPCXEazKWjnBNJWh2y6RRFFDtOKrFpUVV8puTSHaTIkTo'); background-size: cover; background-position: center;"></div>
                        </div>
                    </div>

                    <!-- Task Row 3 -->
                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3 border-start border-4 border-info shadow-sm bg-surface-light" style="cursor: pointer;">
                        <div class="d-flex align-items-center gap-3 overflow-hidden w-100">
                            <div class="rounded-circle border d-flex align-items-center justify-content-center text-white flex-shrink-0" style="width: 24px; height: 24px;">
                                <span class="material-symbols-outlined" style="font-size: 16px;">check</span>
                            </div>
                            <div class="d-flex flex-column min-w-0 flex-grow-1">
                                <p class="fw-bold text-dark mb-0 text-truncate" style="font-size: 0.95rem;">Update Design System Typography Tokens</p>
                                <p class="small text-muted-light mb-0 text-truncate">Design Squad &bull; In Progress</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 ps-3 flex-shrink-0">
                            <span class="small fw-bold text-muted-light text-uppercase tracking-wider">Oct 24</span>
                            <div class="rounded-circle border border-white shadow-sm" style="width: 32px; height: 32px; background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDsQOV_Z3r_kXtNbBXF9YkvKe2UoJxGiKzGpIrkcXGX-Qc_yJU3A7Cajk97lcW1EnL9r-nWznecCLO-7aIBOXg3W8xfEyu7GVTLX0B5IeuJ-luedtt4ZPzZTMOHYGOJq2TEthNM2PnHQIkbh_xiD-SPqYgWJoDC2XCP2gYbWuVUR9sHkPbJA6AKBFKunmk6RiqgLzOaiwdVkz1hiUScohXrgd-dBSk_GQMylIyRoCeeM_VnC8SOu-gNkt2e_wDq62G8EF3aDS8_DFee'); background-size: cover; background-position: center;"></div>
                        </div>
                    </div>

                    <!-- Task Row 4 -->
                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3 border-start border-4 border-secondary shadow-sm bg-surface-light" style="cursor: pointer;">
                        <div class="d-flex align-items-center gap-3 overflow-hidden w-100">
                            <div class="rounded-circle border d-flex align-items-center justify-content-center text-white flex-shrink-0" style="width: 24px; height: 24px;">
                                <span class="material-symbols-outlined" style="font-size: 16px;">check</span>
                            </div>
                            <div class="d-flex flex-column min-w-0 flex-grow-1">
                                <p class="fw-bold text-dark mb-0 text-truncate" style="font-size: 0.95rem;">Client Feedback Sync</p>
                                <p class="small text-muted-light mb-0 text-truncate">Website Redesign &bull; To Do</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 ps-3 flex-shrink-0">
                            <span class="small fw-bold text-muted-light text-uppercase tracking-wider">Oct 26</span>
                            <div class="rounded-circle bg-light border border-secondary border-dashed d-flex align-items-center justify-content-center text-muted fw-bold shadow-sm" style="width: 32px; height: 32px; font-size: 12px;">?</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity Feed -->
        <div class="col-12 col-lg-4">
            <div class="bg-surface-light rounded-4 shadow-soft border border-border-light d-flex flex-column h-100" style="min-height: 500px;">
